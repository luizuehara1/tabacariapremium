rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email_verified == true && 
             exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // --- Product Validation ---
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'image']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() <= 1000 &&
             (!('tag' in data) || (data.tag is string && data.tag.size() <= 50)) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             (!('flavors' in data) || (data.flavors is list));
    }

    // --- Order Validation ---
    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'address', 'items', 'total', 'shipping', 'status', 'createdAt']) &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.address is string && data.address.size() > 0 &&
             data.items is list && data.items.size() > 0 &&
             data.total is number &&
             data.shipping == 10 &&
             data.status == 'Pendente' &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    match /admins/{email} {
      allow read: if isSignedIn() && request.auth.token.email == email && request.auth.token.email_verified == true;
      allow write: if false;
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(incoming()) && 
                    (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'image', 'tag', 'description', 'rating', 'flavors']));
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow list, get: if isAdmin();
      allow create: if isValidOrder(incoming()) && isValidId(orderId);
      allow update: if isAdmin() && (incoming().diff(existing()).affectedKeys().hasOnly(['status']));
      allow delete: if isAdmin();
    }
  }
}
