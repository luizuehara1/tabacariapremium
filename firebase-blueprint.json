{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product for sale in the shop",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "tag": { "type": "string" },
        "rating": { "type": "number" },
        "description": { "type": "string" },
        "flavors": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "price", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A purchase order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "address": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "shipping": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "address", "items", "total"]
    },
    "Admin": {
      "title": "Admin",
      "description": "User with admin privileges",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of all products"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer purchase orders"
    },
    "admins/{adminId}": {
      "schema": "Admin",
      "description": "List of authorized administrators"
    }
  }
}
